<Window x:Class="ChairOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CHAIR Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Grid x:Name="RootGrid">
        <!-- Status dot -->
        <Ellipse x:Name="StatusDot"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Width="10" Height="10" Margin="8,8,0,0"
                 Opacity="0">
            <Ellipse.Fill>
                <SolidColorBrush Color="#BBFF3333"/>
            </Ellipse.Fill>
        </Ellipse>

        <!--
            Crosshair ring: 5 pill-shaped indicators on a semicircle (R=120px)
            above/around screen center, 45 deg apart.

            hard_left  180°  (-120,   0)  rotate  90°
            left       135°  ( -85, -85)  rotate  45°
            center      90°  (   0,-120)  rotate   0°
            right       45°  (  85, -85)  rotate -45°
            hard_right   0°  ( 120,   0)  rotate -90°
        -->
        <Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="0" Height="0" ClipToBounds="False">

            <!-- HARD LEFT -->
            <Border x:Name="DirHardLeft" Canvas.Left="-145" Canvas.Top="-6"
                    Width="50" Height="12" CornerRadius="6" Opacity="0">
                <Border.RenderTransform>
                    <RotateTransform Angle="90" CenterX="25" CenterY="6"/>
                </Border.RenderTransform>
                <Border.Background>
                    <SolidColorBrush Color="#CCFFFFFF"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="Black" Opacity="0.9"/>
                </Border.Effect>
            </Border>

            <!-- LEFT -->
            <Border x:Name="DirLeft" Canvas.Left="-110" Canvas.Top="-91"
                    Width="50" Height="12" CornerRadius="6" Opacity="0">
                <Border.RenderTransform>
                    <RotateTransform Angle="45" CenterX="25" CenterY="6"/>
                </Border.RenderTransform>
                <Border.Background>
                    <SolidColorBrush Color="#CCFFFFFF"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="Black" Opacity="0.9"/>
                </Border.Effect>
            </Border>

            <!-- CENTER -->
            <Border x:Name="DirCenter" Canvas.Left="-25" Canvas.Top="-126"
                    Width="50" Height="12" CornerRadius="6" Opacity="0">
                <Border.Background>
                    <SolidColorBrush Color="#CCFFFFFF"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="Black" Opacity="0.9"/>
                </Border.Effect>
            </Border>

            <!-- RIGHT -->
            <Border x:Name="DirRight" Canvas.Left="60" Canvas.Top="-91"
                    Width="50" Height="12" CornerRadius="6" Opacity="0">
                <Border.RenderTransform>
                    <RotateTransform Angle="-45" CenterX="25" CenterY="6"/>
                </Border.RenderTransform>
                <Border.Background>
                    <SolidColorBrush Color="#CCFFFFFF"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="Black" Opacity="0.9"/>
                </Border.Effect>
            </Border>

            <!-- HARD RIGHT -->
            <Border x:Name="DirHardRight" Canvas.Left="95" Canvas.Top="-6"
                    Width="50" Height="12" CornerRadius="6" Opacity="0">
                <Border.RenderTransform>
                    <RotateTransform Angle="-90" CenterX="25" CenterY="6"/>
                </Border.RenderTransform>
                <Border.Background>
                    <SolidColorBrush Color="#CCFFFFFF"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="6" Color="Black" Opacity="0.9"/>
                </Border.Effect>
            </Border>
        </Canvas>

        <!-- Left event log: bottom-left -->
        <StackPanel x:Name="LeftEventLog"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="60,0,0,60">
            <TextBlock x:Name="LeftLogLine1" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Left">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="LeftLogLine2" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Left">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="LeftLogLine3" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Left">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <!-- Right event log: bottom-right -->
        <StackPanel x:Name="RightEventLog"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,60,60">
            <TextBlock x:Name="RightLogLine1" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Right">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="RightLogLine2" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Right">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="RightLogLine3" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Right">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
