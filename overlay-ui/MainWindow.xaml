<Window x:Class="ChairOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CHAIR Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Grid x:Name="RootGrid">
        <!-- Status dot -->
        <Ellipse x:Name="StatusDot"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Width="10" Height="10" Margin="8,8,0,0"
                 Opacity="0">
            <Ellipse.Fill>
                <SolidColorBrush Color="#BBFF3333"/>
            </Ellipse.Fill>
        </Ellipse>

        <!-- HARD LEFT: thick bright bar, full screen edge -->
        <Border x:Name="LeftHardIndicator"
                HorizontalAlignment="Left" VerticalAlignment="Stretch"
                Width="12" CornerRadius="0,6,6,0"
                Opacity="0" Margin="0,40,0,40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#DDFF6B00" Offset="0"/>
                    <GradientStop Color="#00FF6B00" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- LEFT: medium bar -->
        <Border x:Name="LeftIndicator"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Width="8" Height="300" CornerRadius="0,4,4,0"
                Opacity="0" Margin="40,0,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#AAFFB347" Offset="0"/>
                    <GradientStop Color="#00FFB347" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- HARD RIGHT: thick bright bar, full screen edge -->
        <Border x:Name="RightHardIndicator"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Width="12" CornerRadius="6,0,0,6"
                Opacity="0" Margin="0,40,0,40">
            <Border.Background>
                <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                    <GradientStop Color="#DDFF6B00" Offset="0"/>
                    <GradientStop Color="#00FF6B00" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- RIGHT: medium bar -->
        <Border x:Name="RightIndicator"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Width="8" Height="300" CornerRadius="4,0,0,4"
                Opacity="0" Margin="0,0,40,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                    <GradientStop Color="#AAFFB347" Offset="0"/>
                    <GradientStop Color="#00FFB347" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- CENTER: top bar -->
        <Border x:Name="CenterIndicator"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Width="300" Height="10" CornerRadius="0,0,5,5"
                Opacity="0" Margin="0,0,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#CCFF6B00" Offset="0"/>
                    <GradientStop Color="#00FF6B00" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Left event log: bottom-left, for left/hard_left sounds -->
        <StackPanel x:Name="LeftEventLog"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="60,0,0,60">
            <TextBlock x:Name="LeftLogLine1" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Left">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="LeftLogLine2" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Left">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="LeftLogLine3" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Left">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <!-- Right event log: bottom-right, for right/hard_right sounds -->
        <StackPanel x:Name="RightEventLog"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,60,60">
            <TextBlock x:Name="RightLogLine1" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Right">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="RightLogLine2" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Right">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="RightLogLine3" Opacity="0"
                       FontFamily="Bahnschrift" FontSize="36" FontWeight="Bold"
                       Foreground="#DDE0E0E0" TextAlignment="Right">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
