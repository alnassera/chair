<Window x:Class="ChairOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChairOverlay"
        Title="CHAIR Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Grid x:Name="RootGrid">
        <!-- Status dot -->
        <Ellipse x:Name="StatusDot"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Width="10" Height="10" Margin="8,8,0,0"
                 Opacity="0">
            <Ellipse.Fill>
                <SolidColorBrush Color="#BBFF3333"/>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Polar ring: centered on crosshair -->
        <Canvas HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="0" Height="0" ClipToBounds="False">
            <local:PolarRingControl x:Name="PolarRing"
                Canvas.Left="-250" Canvas.Top="-250"
                Width="500" Height="500" />
        </Canvas>
    </Grid>
</Window>
